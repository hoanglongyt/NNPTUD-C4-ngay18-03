  "item": [
    {
      "name": "1. Create Role",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"admin_manual\",\n  \"description\": \"Quyen quan tri\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/roles",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "roles"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create role status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "if (jsonData && jsonData._id) {",
              "    pm.collectionVariables.set('roleId', jsonData._id);",
              "}"
            ]
          }
        }
      ]
    },
    {
